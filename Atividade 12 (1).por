programa {
	funcao inicio() {
		cadeia assentos[2][2]

		escreva("Quem sentará na Linha 0, Coluna 0? ")
		leia(assentos[0][0])

		escreva("Quem sentará na Linha 0, Coluna 1? ")
		leia(assentos[0][1])

		escreva("Quem sentará na Linha 1, Coluna 0? ")
		leia(assentos[1][0])

		escreva("Quem sentará na Linha 1, Coluna 1? ")
		leia(assentos[1][1])
	}
}
